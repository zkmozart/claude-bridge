# Claude Bridge Configuration
# Copy this file to .env and fill in the values.

# API token for authenticating requests to the Bridge API
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_API_TOKEN=change-me-to-a-random-string

# Path to your git repository (absolute path)
# Overrides bridge.config.json repoPath
# REPO_PATH=/path/to/your/repo

# Port for the Bridge daemon HTTP server (default: 3100)
# PORT=3100

# Poll interval in milliseconds (default: 30000)
# POLL_INTERVAL_MS=30000

# Path to Claude Code CLI binary (default: "claude")
# CLAUDE_CLI_PATH=claude

# Claude API key (if using API key auth instead of OAuth)
# If not set, the daemon uses OAuth via ~/.claude/.credentials.json
# CLAUDE_API_KEY=sk-ant-...

# WSL distro name for autostart script (default: Ubuntu)
# BRIDGE_WSL_DISTRO=Ubuntu

# Listen IP for portproxy script (your Tailscale/VPN IP)
# BRIDGE_LISTEN_IP=100.x.y.z
